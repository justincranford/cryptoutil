# Normalize all text files in the repository; working-tree line endings follow core.autocrlf
* text=auto

# Windows-specific files that must remain CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — do not attempt line ending conversion
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.key binary
*.crt binary
*.pem binary
*.der binary
*.bin binary
