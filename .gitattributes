# LF everywhere: all text files use LF in both repository storage and working tree.
# .gitattributes eol=lf overrides core.autocrlf for all matched files — Windows developers
# get LF checkouts, not CRLF. No need to set or change core.autocrlf globally.
* text=auto eol=lf

# Binary files — do not attempt line ending conversion
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.der binary
*.bin binary
*.jar binary
*.war binary
*.ear binary
*.sar binary
*.p12 binary
*.pfx binary
*.zip binary
*.tar binary
*.gz binary
